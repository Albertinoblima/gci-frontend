# Arquivo: gci-frontend/.env

# URL completa da API para chamadas HTTP (usada pelo Axios/apiClient)
VITE_API_BASE_URL=http://localhost:3001/api

# URL raiz do Backend para a conexão do Socket.IO
VITE_BACKEND_URL=http://localhost:3001

# Configurações do PIN Company Service
VITE_PIN_COMPANY_ENABLED=false
VITE_PIN_COMPANY_API=/api/pin-company

# Configurações para compatibilidade
REACT_APP_PIN_COMPANY_ENABLED=false
REACT_APP_PIN_COMPANY_API=/api/pin-company